{
  "webdav_url": "http://localhost:5244/dav",
  "webdav_username": "admin",
  "webdav_password": "your_password",
  "webdav_remote_dir": "/115/Media",
  "local_watch_dir": "/data",
  "video_extensions": [".mkv", ".mp4", ".ts", ".m2ts", ".avi", ".iso"],
  "ignore_dirs": ["@eaDir", "@Recycle", "#recycle", "metadata", "tmp"],
  "concurrent_uploads": 3,
  "overwrite_policy": "skip_if_same_size",
  "retry_count": 3,
  "single_file_timeout_minutes": 60,
  "monitor_enabled": false,
  "scheduler_enabled": false,
  "scheduler_time": "03:00",
  "sync_speed_limit": "10M",
  "webdav_snapshot_ttl_hours": 23,
  "log_retain_days": 30
}
